{
  "name": "infinite-todo",
  "private": true,
  "type": "module",
  "scripts": {
    "build:client": "node scripts/build-client.mts",
    "pretypecheck": "npm run build:client",
    "typecheck": "tsc --build",
    "run-test-suite": "playwright test",
    "dev": "node scripts/build-client.mts --watch & wrangler dev",
    "predeploy": "node scripts/generate-deployment-timestamp.mts deploy && npm run typecheck",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260712.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2",
    "wrangler": "^4"
  }
}
