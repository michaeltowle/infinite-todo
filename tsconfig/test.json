// The test suite. Playwright compiles the specs itself, so this project exists only
// so `npm run typecheck` covers them too. DOM lib because page.evaluate() callbacks
// run in the browser; Node types for the config. No Cloudflare types — a spec talks
// to the Worker over HTTP, never imports it.
{
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "outDir": "../.tsbuild/test"
  },
  "include": ["../test/**/*.ts", "../playwright.config.ts"],
  // A spec never imports the Worker (it talks to it over HTTP), but the client's pure,
  // DOM-free logic modules are fair game to unit-test directly — optparse.spec.ts exercises
  // the parser this way, since due-date has no page surface to assert against yet. The
  // reference lets tsc resolve that import to the client project's declarations.
  "references": [{ "path": "./client.json" }]
}
